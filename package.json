{
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "tsdown": "^0.21.10"
    }
  },
  "type": "module",
  "scripts": {
    "u": "bun --sequential format lint build test",
    "format": "oxfmt",
    "lint": "oxlint",
    "build": "bun run --parallel --filter='./packages/**' build",
    "test": "bun run --parallel --filter='./packages/**' test"
  },
  "devDependencies": {
    "@gameroman/config": "^0.0.7",
    "@types/bun": "^1.3.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
