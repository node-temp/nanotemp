{
  "name": "@nanotemp/quick-temp",
  "version": "0.0.1",
  "license": "MIT",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
