  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun test",
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
